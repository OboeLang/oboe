import mathlib as m
import square from mathlib

func main(array args) {
    print(m.square(6))
    print(square(7))

    let numbers = [1, 2, 3, 4]
    let total = 0
    for (n in numbers) {
        total = total + n
    }
    print(total)

    let person = {"name": "Ada", "age": 36}
    print(person["name"])
    person["age"] = 37
    print(person["age"])
}
