// custom top-level operators and class operator overloading
operator ||> (int a, int b) {
    var c = a * 10
    return c + b
}

operator <+> (int a, int b) {
    return a + b + 100
}

class Vector2 {
    func init(this, int x, int y) {
        let this.x = x
        let this.y = y
    }

    operator + (this, Vector2 other) {
        return Vector2(this.x + other.x, this.y + other.y)
    }

    operator ||> (this, Vector2 other) {
        return Vector2(this.x * other.x, this.y * other.y)
    }

    func show(this) {
        print("(${this.x}, ${this.y})")
    }
}

func main(array args) {
    print(5 ||> 8)
    print(1 <+> 2)
    print(2 ||> 3 ||> 4)

    var v = Vector2(1, 2) + Vector2(3, 4)
    v.show()
    var w = Vector2(2, 3) ||> Vector2(4, 5)
    w.show()
    var u = Vector2(1, 1) + Vector2(2, 2) + Vector2(3, 3)
    u.show()
}
