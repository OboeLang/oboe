func main(array args) {
    print("ab" x 3)
    print("-" x 0)
    print("[${"-" x 5}]")

    // a variable named x coexists with the repetition operator
    let x = 2
    print(x)
    print(x + 1)
    print("ho" x x)
    print("z" x (x * 3))
}
