func main(array args) {
    // precedence
    print(2 + 3 * 4)
    print((2 + 3) * 4)
    print(10 - 2 - 3)
    print(20 / 3)
    print(-5 + 3)
    print(-(2 * 3))
    print(7 % 3)

    // comparisons
    print(1 < 2)
    print(2 <= 2)
    print(3 > 4)
    print(5 >= 5)
    print(1 == 1)
    print(1 != 1)

    // logic keywords and symbols are interchangeable
    print(true and false)
    print(true && true)
    print(false or true)
    print(false || false)
    print(!false)
}
