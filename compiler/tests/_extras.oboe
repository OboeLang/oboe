// a module declaring an event, a custom operator, and a cimport
cimport abs from "libc.so.6"

event ModEvent = event(str msg)

on ModEvent as e {
    print("module handler: ${e.msg}")
}

operator <*> (int a, int b) {
    return a * b + 1
}

func moduleWork(int n) {
    ModEvent.fire("from module")
    return abs(n) <*> 2
}
