// events: payloads, `as` binding, multiple handlers in declaration order
event Plain = event()
event Named = event(str name, int age)

on Plain {
    print("plain fired")
}

on Named as e {
    print("${e.name} is ${e.age}")
}

on Named {
    print("second handler")
}

on Named as n {
    print("third: ${n.name}")
}

func main(array args) {
    Plain.fire()
    Named.fire("Jade", 20)
    Named.fire("Robin", 21)
}
