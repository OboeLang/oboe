// events, custom operators, and cimports declared in a module, used from main
import _extras

on ModEvent as e {
    print("main handler: ${e.msg}")
}

func main(array args) {
    print(3 <*> 4)
    ModEvent.fire("from main")
    print(_extras.moduleWork(-5))
}
