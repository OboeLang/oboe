// the four declaration forms from the spec, plus class fields in new syntax
var a = 1
int b = 2
const var c = 3
const int d = 4

class Counter {
    static int count = 0
    string label = "counter"

    static func increment() {
        Counter.count = Counter.count + 1
    }
}

func main(array args) {
    print(a + b + c + d)
    var s = "typed"
    string t = "and untyped"
    print("${s} ${t}")
    Counter.increment()
    Counter.increment()
    Counter.increment()
    print(Counter.count)
    int i = 10
    i = i + 5
    print(i)
}
